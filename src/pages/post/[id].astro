---
import BlogPost from "../../layouts/BlogPost.astro";
import { getBlog, getBlogs } from "../../lib/microcms";
import { convertOgpCards } from "../../lib/ogpCard";

export async function getStaticPaths() {
  const { contents: posts } = await getBlogs({ limit: 100 });
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}

const post = Astro.props;
const content = await convertOgpCards(post.content);
---

<BlogPost
  title={post.title}
  description={post.description ?? ""}
  pubDate={new Date(post.publishedAt)}
  heroImage={post.eyecatch?.url}
>
  <div set:html={content} />
</BlogPost>
